# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# Supabase project URL (from: Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Secret API key (from: Settings → API Keys → Secret keys)
# WARNING: This is a privileged key — keep it secret! (format: sb_secret_...)
SERVICE_ROLE_KEY=your-sb-secret-key-here

# Google reCAPTCHA v2/v3 secret key (from: Google reCAPTCHA admin console)
RECAPTCHA_SECRET=your-recaptcha-secret-here
